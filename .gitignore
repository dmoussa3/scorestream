# ── Checkpoints ────────────────────────────────────────────────
# Spark offset tracking — machine specific, regenerated on startup
checkpoints/scores/*
checkpoints/standings/*
checkpoints/goals/*
checkpoints/standings_debug/*
!checkpoints/scores/.gitkeep
!checkpoints/standings/.gitkeep
!checkpoints/goals/.gitkeep

# ── Archive ────────────────────────────────────────────────────
# Parquet snapshots — too large for git, regenerated by Airflow
archive/*
!archive/.gitkeep

# ── Environment files ──────────────────────────────────────────
# Never commit credentials
.env
.env.local
.env.production
*.env

# ── Docker ─────────────────────────────────────────────────────
# Ivy cache — JARs downloaded by Spark, large and regenerated
ivy_cache/

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Node / React ───────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/.env.local
frontend/.env.production

# ── macOS ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ───────────────────────────────────────────────────────
*.log
logs/

# ── Airflow ────────────────────────────────────────────────────
# Airflow generates these locally
airflow/logs/
airflow/plugins/
airflow.cfg
airflow.db
webserver_config.py

# ── Miscellaneous ───────────────────────────────────────────────
test.py